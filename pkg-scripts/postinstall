#!/bin/sh

# Eburon PKG Installer - Postinstall Script
# Installs the Eburon Virtual Audio driver

echo "Eburon postinstall: Starting installation..."

# Set correct permissions on the installed app
if [ -d "/Applications/Eburon.app" ]; then
    echo "Eburon postinstall: Setting app permissions..."
    chmod -R 755 /Applications/Eburon.app
fi

# Install the virtual audio driver from the app bundle
DRIVER_SOURCE="/Applications/Eburon.app/Contents/Resources/resources/drivers/EburonVirtualAudio.driver"
DRIVER_DEST="/Library/Audio/Plug-Ins/HAL/EburonVirtualAudio.driver"

# Ensure HAL plugins directory exists
HAL_DIR="/Library/Audio/Plug-Ins/HAL"
if [ ! -d "$HAL_DIR" ]; then
    echo "Eburon postinstall: Creating HAL plugins directory..."
    mkdir -p "$HAL_DIR"
    if [ $? -ne 0 ]; then
        echo "Eburon postinstall: ERROR - Failed to create HAL plugins directory"
        exit 1
    fi
    chown root:wheel "$HAL_DIR"
    chmod 755 "$HAL_DIR"
fi

if [ -d "$DRIVER_SOURCE" ]; then
    echo "Eburon postinstall: Installing virtual audio driver..."

    # Remove old driver if it exists
    if [ -d "$DRIVER_DEST" ]; then
        echo "Eburon postinstall: Removing old driver..."
        rm -rf "$DRIVER_DEST"
    fi

    # Copy the driver to the HAL plugins directory
    echo "Eburon postinstall: Copying driver to $DRIVER_DEST..."
    cp -R "$DRIVER_SOURCE" "$DRIVER_DEST"

    # Set correct permissions on the driver
    echo "Eburon postinstall: Setting driver permissions..."
    chown -R root:wheel "$DRIVER_DEST"
    chmod -R 755 "$DRIVER_DEST"

    # Restart CoreAudio to load the driver
    echo "Eburon postinstall: Restarting CoreAudio to load driver..."
    # Try multiple methods to ensure CoreAudio restarts regardless of permission level
    killall coreaudiod 2>/dev/null || \
    launchctl kickstart -k system/com.apple.audio.coreaudiod 2>/dev/null || \
    launchctl kill SIGTERM system/com.apple.audio.coreaudiod 2>/dev/null || true

    echo "Eburon postinstall: Virtual audio driver installed successfully"
else
    echo "Eburon postinstall: Warning - Virtual audio driver not found in app bundle"
fi

echo "Eburon postinstall: Installation completed"
exit 0