#!/bin/sh

# Eburon PKG Installer - Preinstall Script
# Prepares the system for Eburon Virtual Audio driver installation

echo "Eburon preinstall: Preparing system for installation..."

# Create HAL plugin directory if it doesn't exist
echo "Eburon preinstall: Ensuring HAL plugin directory exists..."
mkdir -p /Library/Audio/Plug-Ins/HAL
chown root:wheel /Library/Audio/Plug-Ins/HAL
chmod 755 /Library/Audio/Plug-Ins/HAL

# Remove any existing Eburon Virtual Audio installation
if [ -d "/Library/Audio/Plug-Ins/HAL/EburonVirtualAudio.driver" ]; then
    echo "Eburon preinstall: Removing existing Eburon Virtual Audio driver..."
    rm -rf /Library/Audio/Plug-Ins/HAL/EburonVirtualAudio.driver
    echo "Eburon preinstall: Old driver removed"
fi

# Also check for the app in case of reinstallation
if [ -d "/Applications/Eburon.app" ]; then
    echo "Eburon preinstall: Found existing Eburon.app, will be replaced..."
fi

echo "Eburon preinstall: System preparation complete"
exit 0