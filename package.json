{
  "name": "sokuji",
  "productName": "Sokuji",
  "version": "0.32.1",
  "sidecarVersion": "0.1.8",
  "private": true,
  "main": "dist-electron/main.js",
  "homepage": "./",
  "description": "AI-powered live speech translation application",
  "author": {
    "name": "Kizuna AI Lab",
    "email": "contact@kizuna.ai"
  },
  "build": {
    "appId": "ai.kizunaai.sokuji",
    "productName": "Sokuji",
    "asar": true,
    "directories": {
      "output": "out/make-linux"
    },
    "files": [
      "package.json",
      "dist-electron/**/*",
      "build/**/*",
      "!build/**/*.map",
      "!build/assets/test-tone.mp3",
      "!build/wasm/**",
      "build/wasm/sherpa-onnx-asr/**",
      "build/wasm/sherpa-onnx-asr-stream/**",
      "build/wasm/sherpa-onnx-tts/**",
      "build/wasm/ort/**",
      "build/wasm/vad/**",
      "build/wasm/piper-plus/**",
      "build/wasm/gtcrn/**"
    ],
    "extraResources": [
      "assets",
      "resources"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "AudioVideo",
      "icon": "assets/icon.png",
      "executableName": "sokuji"
    },
    "mac": {
      "target": [
        {
          "target": "pkg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "identity": null
    },
    "pkg": {
      "scripts": "../pkg-scripts",
      "installLocation": "/Applications",
      "isRelocatable": false,
      "isVersionChecked": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "${name}_${version}_${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "kizuna-ai-lab",
      "repo": "sokuji"
    },
    "afterPack": "./scripts/electron-builder-fuses.js"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.15",
    "@google/genai": "^1.46.0",
    "@huggingface/transformers": "^4.2.0",
    "@ricky0123/vad-web": "^0.0.30",
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^27.5.2",
    "@types/node": "^24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "better-auth": "^1.6.2",
    "electron-audio-loopback": "^1.0.6",
    "electron-conf": "^1.3.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3",
    "fzstd": "^0.1.1",
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.1.0",
    "idb": "^8.0.3",
    "livekit-client": "^2.15.2",
    "lucide-react": "^0.515.0",
    "mpg123-decoder": "^1.0.3",
    "openai": "^6.29.0",
    "openai-realtime-api": "1.0.8",
    "posthog-js-lite": "^4.1.0",
    "protobufjs": "^8.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^15.5.2",
    "react-icons": "^5.6.0",
    "react-joyride": "^3.2.0",
    "react-router-dom": "^7.12.0",
    "sass": "^1.78.0",
    "tar-stream": "^3.2.0",
    "uuid": "^11.1.0",
    "web-vitals": "^2.1.4",
    "zustand": "^5.0.8"
  },
  "optionalDependencies": {
    "naudiodon": "^2.3.6",
    "win-core-audio": "^1.2.0"
  },
  "overrides": {
    "form-data": "^4.0.4",
    "axios": "^1.9.0",
    "onnxruntime-node": "npm:empty-npm-package@1.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-flatpak": "^7.11.1",
    "@electron-forge/maker-pkg": "^7.11.1",
    "@electron-forge/maker-snap": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^2.0.0",
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^24",
    "@types/react-router-dom": "^5.3.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "40.8.5",
    "electron-builder": "^25.1.8",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.0.0",
    "protobufjs-cli": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "electron:dev": "vite",
    "electron:build": "npm run build && npm run make",
    "electron:start": "electron .",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "make:pkg": "npm run build && electron-builder --mac pkg --publish never -c.directories.output=out/make-mac",
    "postinstall": "electron-rebuild && bash scripts/copy-ort-wasm.sh",
    "eval": "tsx evals/runner/index.ts",
    "eval:validate": "tsx evals/runner/index.ts validate",
    "eval:list": "tsx evals/runner/index.ts list",
    "extension:build": "cd extension && npx vite build",
    "extension:dev": "cd extension && npx vite build --watch --mode development",
    "sidecar:setup": "bash sidecar/setup.sh"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "env": {
      "es2020": true,
      "browser": true,
      "node": true
    },
    "parserOptions": {
      "ecmaVersion": 2020
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "forge": "./forge.config.js"
  }
}
